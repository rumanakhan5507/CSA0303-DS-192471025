#include <stdio.h>

void fibo(int n)
{
    int a = 0, b = 1, c, i;

    if (n >= 1)
        printf("%d", a);

    if (n >= 2)
        printf(" %d", b);

    for (i = 3; i <= n; i++)
    {
        c = a + b;
        printf(" %d", c);
        a = b;
        b = c;
    }
}

int main()
{
    int n;
    scanf("%d", &n);
    fibo(n);
    return 0;
}

INPUT: 7
OUTPUT: 0 1 1 2 3 5 8
